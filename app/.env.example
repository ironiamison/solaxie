# ── Production — solaxie.com ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://solaxie.com

# Mainnet RPC (Helius recommended — public RPC rate-limits under load)
NEXT_PUBLIC_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# Devnet/testing: https://beta.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Deployed Anchor program (see program/scripts/deploy.sh)
NEXT_PUBLIC_PROGRAM_ID=FYvhXM6Jv4crAVWcpZYtGT9WN2Ai2z9cUpY2EY8CTCcg

# Your pump.fun SPL token mint (6 decimals)
NEXT_PUBLIC_TOKEN_MINT=YOUR_PUMPFUN_MINT_HERE

# ── Vercel Blob (required for leaderboard, feed, stats, cloud saves) ───────────
# Create at vercel.com → Storage → Blob → connect to project
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXX
